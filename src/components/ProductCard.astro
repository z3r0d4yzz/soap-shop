---
import { formatPrice } from "../lib/format";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

interface Props {
  id: string;
  name: string;
  priceCents: number;
  currency?: string;
  description: string;
  image?: string;
}

const {
  id,
  name,
  priceCents,
  currency = "CHF",
  description,
  image = "",
} = Astro.props;

const imageUrl = image ? `${base}/${image}` : "";
---

<article class="rounded-3xl border border-stone-200 bg-white p-6 shadow-sm">
  <a href={`${import.meta.env.BASE_URL}produkte/${id}`} class="block">

    {
  imageUrl ? (
    <img
      src={imageUrl}
      alt={name}
      class="mb-4 aspect-square w-full rounded-2xl object-cover"
    />
  ) : (
    <div class="mb-4 aspect-square rounded-2xl bg-stone-200"></div>
  )
}

    <h2 class="text-xl font-semibold">{name}</h2>
    <p class="mt-2 text-stone-600">{description}</p>
    <p class="mt-4 font-medium">{priceCents}</p>
  </a>

  <div class="mt-4 flex gap-3">
    <a
      href={`${import.meta.env.BASE_URL}produkte/${id}`}
      class="inline-block rounded-full border border-stone-300 px-5 py-3"
    >
      Details
    </a>
  <button
  class="mt-4 inline-block rounded-full bg-stone-900 px-5 py-3 text-white"
  data-product-id={id}
>
  In den Warenkorb
</button>

<script>
  import { addToCart } from "../lib/cart";

  document.querySelectorAll("[data-product-id]").forEach((button) => {
    button.addEventListener("click", () => {
      const id = button.getAttribute("data-product-id");
      if (!id) return;
      addToCart(id, 1);
      alert("Zum Warenkorb hinzugefuegt");
    });
  });
  </script>  
   
  </div>
</article>