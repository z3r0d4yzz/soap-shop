---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Kontakt | Seifen Shop Vorlage">
  <section class="mx-auto max-w-4xl px-6 py-16">
    <h1 class="text-4xl font-semibold">Kontakt</h1>
    <p class="mt-4 text-stone-600">
      Diese Angaben werden spaeter durch die echten Kontaktdaten des Kunden ersetzt.
    </p>

    <div class="mt-10 rounded-3xl border border-stone-200 bg-white p-8 shadow-sm">
      <p><strong>Markenname:</strong> Platzhalter Marke</p>
      <p class="mt-3"><strong>E-Mail:</strong> kontakt@beispiel.ch</p>
      <p class="mt-3"><strong>Telefon:</strong> +41 00 000 00 00</p>
      <p class="mt-3"><strong>Adresse:</strong> Musterstrasse 1, 8000 Zuerich</p>
    </div>
  </section>
</BaseLayout>