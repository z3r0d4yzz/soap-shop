---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { products } from "../../data/products";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { id: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
---

<BaseLayout title={`${product.name} | Seifen Shop Vorlage`}>
  <section class="mx-auto max-w-6xl px-6 py-16">
    <a href={`${import.meta.env.BASE_URL}shop`} class="text-sm text-stone-500 underline">Zurueck zum Shop</a>

    <div class="mt-8 grid gap-10 md:grid-cols-2">
      <div>
        {
          product.image ? (
            <img
              src={product.image}
              alt={product.name}
              class="aspect-square w-full rounded-3xl object-cover"
            />
          ) : (
            <div class="aspect-square rounded-3xl bg-stone-200"></div>
          )
        }
      </div>

      <div>
        <p class="text-sm uppercase tracking-[0.2em] text-stone-500">
          Produktdetail
        </p>

        <h1 class="mt-3 text-4xl font-semibold">{product.name}</h1>
        <p class="mt-4 text-lg text-stone-600">{product.description}</p>
        <p class="mt-6 text-2xl font-medium">{product.price}</p>

        <div class="mt-8 rounded-3xl border border-stone-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-semibold">Beschreibung</h2>
          <p class="mt-3 text-stone-600">{product.longDescription}</p>
        </div>

        <div class="mt-8 flex gap-4">
          <a
            href={product.twintLink}
            class="rounded-full bg-stone-900 px-6 py-3 text-white"
          >
            Mit TWINT bezahlen
          </a>

          <a href={`${import.meta.env.BASE_URL}kontakt`} class="rounded-full border border-stone-300 px-6 py-3">
            Kontakt
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>