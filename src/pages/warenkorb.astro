---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Warenkorb | Seifen Shop Vorlage">
  <section class="mx-auto max-w-5xl px-6 py-16">
    <h1 class="text-4xl font-semibold">Warenkorb</h1>
    <div id="cart-root" class="mt-10"></div>
  </section>

  <script type="module">
    import { getCart, updateQty, removeFromCart } from "../lib/cart";
    const products = await import("../data/products.ts");
    const root = document.getElementById("cart-root");

    const formatPrice = (cents) =>
      new Intl.NumberFormat("de-CH", {
        style: "currency",
        currency: "CHF",
      }).format(cents / 100);

    function render() {
      const cart = getCart();
      const items = cart.map((item) => {
        const product = products.products.find((p) => p.id === item.id);
        return product ? { ...product, qty: item.qty } : null;
      }).filter(Boolean);

      const total = items.reduce((sum, item) => sum + item.priceCents * item.qty, 0);

      if (!items.length) {
        root.innerHTML = "<p>Ihr Warenkorb ist leer.</p>";
        return;
      }

      root.innerHTML = `
        <div class="space-y-4">
          ${items.map((item) => `
            <div class="rounded-2xl border border-stone-200 bg-white p-6">
              <div class="flex items-center justify-between gap-4">
                <div>
                  <h2 class="text-xl font-semibold">${item.name}</h2>
                  <p class="text-stone-600">${formatPrice(item.priceCents)}</p>
                </div>
                <div class="flex items-center gap-3">
                  <input type="number" min="1" value="${item.qty}" data-qty-id="${item.id}" class="w-20 rounded border px-3 py-2" />
                  <button data-remove-id="${item.id}" class="rounded border px-4 py-2">Entfernen</button>
                </div>
              </div>
            </div>
          `).join("")}
          <div class="mt-8 rounded-2xl border border-stone-200 bg-white p-6">
            <p class="text-xl font-semibold">Total: ${formatPrice(total)}</p>
            <a href="${import.meta.env.BASE_URL}checkout/" class="mt-4 inline-block rounded-full bg-stone-900 px-6 py-3 text-white">
              Weiter zum Checkout
            </a>
          </div>
        </div>
      `;

      document.querySelectorAll("[data-qty-id]").forEach((input) => {
        input.addEventListener("change", (e) => {
          updateQty(e.target.getAttribute("data-qty-id"), Number(e.target.value));
          render();
        });
      });

      document.querySelectorAll("[data-remove-id]").forEach((button) => {
        button.addEventListener("click", () => {
          removeFromCart(button.getAttribute("data-remove-id"));
          render();
        });
      });
    }

    render();
  </script>
</BaseLayout>